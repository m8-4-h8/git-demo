# Copy this file to .env and fill in your real values.
# .env is git-ignored and must never be committed.

# Telegram bot token from @BotFather
BOT_TOKEN=

# Optional: path to the SQLite database file (default: ironsworn.db)
# DB_PATH=ironsworn.db

# Narrator (optional LLM prose after each roll).
# With NARRATOR_ENABLED=true the bot adds a short narration after each roll
# (needs a running Ollama server — see below). Set it to false to run with
# mechanics only — the bot works either way, no errors when disabled.
NARRATOR_ENABLED=true

# AI Game Master (optional). With GM_ENABLED=true, /gm runs a campaign and the
# GM describes the next scene after each roll (needs a running Ollama server).
# The GM only narrates — it never resolves mechanics. Disable to run without it.
GM_ENABLED=true

# Ollama server for the narrator & GM (only used when one of them is enabled).
# Defaults work for a local `ollama serve`; override the model to taste.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral
